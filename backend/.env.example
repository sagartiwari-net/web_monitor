# Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to git

# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
# Format: mongodb+srv://<user>:<pass>@cluster.mongodb.net/<dbname>
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/<dbname>

# ─── JWT ──────────────────────────────────────────────────
# Use a long, random string. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_random_hex_here
JWT_EXPIRES_IN=7d

# ─── Google Gemini AI ─────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Google PageSpeed Insights ────────────────────────────
# Enable API: https://console.cloud.google.com/apis/library/pagespeedonline.googleapis.com
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# ─── UPI Payment ──────────────────────────────────────────
UPI_ID=yourname@upi
UPI_PAYEE_NAME=Web Monitor Platform

# ─── Plan Pricing (in INR) ────────────────────────────────
PRICE_BASIC=299
PRICE_PRO=599
PRICE_ELITE=1499
